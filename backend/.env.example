PORT=5000
NODE_ENV=development

# Comma-separated list of allowed target hostnames (empty = allow all)
# Example: reverse-proxy-p1ne.onrender.com
ALLOWED_HOSTS=reverse-proxy-p1ne.onrender.com

# Frontend origin for CORS (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URL of this proxy server (used for URL rewriting)
PROXY_PUBLIC_URL=http://localhost:5000

# Request timeout in milliseconds
PROXY_TIMEOUT_MS=30000

# Max response body size to rewrite (bytes) — larger bodies are streamed without rewrite
MAX_REWRITE_BYTES=5242880

# MongoDB — duplicate registration saves go to the "proxyData" database
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=proxyData

# Default embedded site (used as source metadata on capture)
DEFAULT_TARGET_URL=https://reverse-proxy-p1ne.onrender.com/
